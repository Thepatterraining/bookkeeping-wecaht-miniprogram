/**
 * 折线图组件样式
 * 实现卡片式布局、响应式图表区域、Tab 切换样式
 * 支持屏幕尺寸：320px - 414px
 */

/* ==================== 容器样式 ==================== */

/* 主容器：卡片式设计，圆角、阴影、内边距 */
.line-chart-container {
  background-color: #ffffff;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  /* 添加过渡效果，使样式变化更平滑 */
  transition: all 0.3s ease;
}

/* 小屏幕适配（≤320px，如 iPhone SE） */
@media screen and (max-width: 320px) {
  .line-chart-container {
    margin: 16rpx;
    padding: 24rpx;
    border-radius: 16rpx;
  }
}

/* ==================== 头部样式 ==================== */

/* 头部容器：flex 布局，标题和 Tab 两端对齐 */
.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

/* 标题样式：加粗、深色 */
.chart-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

/* Tab 按钮组容器：flex 布局，圆角背景 */
.dimension-tabs {
  display: flex;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  overflow: hidden;
}

/* 单个 Tab 项 */
.tab-item {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #666666;
  /* 过渡效果 */
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  /* 相对定位，用于伪元素 */
  position: relative;
  /* 防止文字选中 */
  user-select: none;
}

/* Tab 点击态 */
.tab-item:active {
  opacity: 0.7;
}

/* Tab 激活状态：主题色背景、白色文字 */
.tab-item.active {
  background-color: #07c160;
  color: #ffffff;
  font-weight: 500;
  /* 添加阴影效果 */
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

/* 小屏幕适配 Tab */
@media screen and (max-width: 320px) {
  .tab-item {
    padding: 10rpx 16rpx;
    font-size: 24rpx;
  }
}

/* ==================== 图表主体样式 ==================== */

/* 图表区域容器 */
.chart-body {
  width: 100%;
  min-height: 400rpx;
  /* 相对定位 */
  position: relative;
}

/* Canvas 包裹层：确保图表响应式 */
.chart-wrapper {
  width: 100%;
  height: 400rpx;
  /* 过渡效果 */
  transition: height 0.3s ease;
}

/* 小屏幕适配图表高度 */
@media screen and (max-width: 320px) {
  .chart-body {
    min-height: 320rpx;
  }
  .chart-wrapper {
    height: 320rpx;
  }
}

/* 大屏幕适配（≥375px） */
@media screen and (min-width: 375px) {
  .chart-wrapper {
    height: 450rpx;
  }
}

/* 超大屏幕适配（≥414px） */
@media screen and (min-width: 414px) {
  .chart-wrapper {
    height: 500rpx;
  }
}

/* ==================== 空状态样式 ==================== */

/* 空状态容器：居中布局 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

/* 空状态图标 */
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

/* 空状态主文字 */
.empty-text {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

/* 空状态提示文字 */
.empty-hint {
  font-size: 24rpx;
  color: #cccccc;
}

/* ==================== 错误状态样式 ==================== */

/* 错误状态容器：居中布局 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

/* 错误状态图标 */
.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

/* 错误状态文字 */
.error-text {
  font-size: 28rpx;
  color: #ff4d4f;
  margin-bottom: 24rpx;
}

/* 重试按钮 */
.retry-btn {
  padding: 16rpx 48rpx;
  background-color: #07c160;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 8rpx;
  transition: opacity 0.3s ease;
}

.retry-btn:active {
  opacity: 0.8;
}

/* ==================== 底部图例样式 ==================== */

/* 底部图例容器：flex 居中布局 */
.chart-footer {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
  /* 添加动画效果 */
  animation: fadeIn 0.5s ease;
}

/* 淡入动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 单个图例项 */
.legend-item {
  display: flex;
  align-items: center;
  margin: 0 24rpx;
  /* 过渡效果 */
  transition: transform 0.2s ease;
}

/* 图例项点击态 */
.legend-item:active {
  transform: scale(0.95);
}

/* 图例圆点 */
.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  /* 添加阴影效果 */
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

/* 收入图例颜色：绿色 */
.legend-dot.income {
  background-color: #07c160;
}

/* 支出图例颜色：红色 */
.legend-dot.expense {
  background-color: #fa5151;
}

/* 图例文字 */
.legend-label {
  font-size: 24rpx;
  color: #666666;
}

/* 小屏幕适配图例 */
@media screen and (max-width: 320px) {
  .chart-footer {
    margin-top: 16rpx;
    padding-top: 16rpx;
  }
  .legend-item {
    margin: 0 16rpx;
  }
  .legend-label {
    font-size: 22rpx;
  }
}
